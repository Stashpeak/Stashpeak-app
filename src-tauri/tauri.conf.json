{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Stashpeak",
  "version": "0.1.0",
  "identifier": "com.stashpeak.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Stashpeak",
        "width": 1100,
        "height": 700,
        "minWidth": 800,
        "minHeight": 500
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "notification": null,
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDkzQTUyNTUzREI1OTNGQUYKUldTdlAxbmJVeVdsazR4dkErOWF2UkpzTXhLRDV4ckpESVEzV05TbTg3K3hRQTl5emtKeEJ0T0sK",
      "endpoints": [
        "https://github.com/Stashpeak/app/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
